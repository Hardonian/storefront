# Storefront environment configuration
# Copy to .env and edit as needed

# Path to the revenue-os SQLite database
DB_PATH=/home/scott/ai-lab/revenue-os/revenue-os.db

# Directory containing landing-page HTML files
LANDING_DIR=/home/scott/ai-lab/reports/landing

# Directory containing legal Markdown documents
LEGAL_DIR=/home/scott/ai-lab/legal

# API key for authenticated GET /api/leads endpoint
# Set this to a strong random string; clients must pass via X-API-Key header
API_KEY=chang-me-to-a-strong-secret

# Port to listen on
PORT=8020

# Rate limit: max POST requests per minute per IP
RATE_LIMIT_PER_MIN=20

# Debug mode
DEBUG=false